# Backend API
PORT=5000
JWT_SECRET=your_jwt_secret_here

# MongoDB (Replace with your Atlas URI for production)
# Example: mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/reimbursement?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/reimbursement

# AI/ML
GROQ_API_KEY=your_groq_api_key_here

# OCR (Managed by ml-service)
# In Docker, this defaults to 'tesseract'
TESSERACT_CMD=tesseract

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:5000
